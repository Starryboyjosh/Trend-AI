{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hitrendy.local/schemas/business-profile.schema.json",
  "title": "BusinessProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "category", "country", "city", "primary_product", "target_audience", "preferred_platforms", "primary_objective"],
  "properties": {
    "name": {"type": "string", "minLength": 1, "maxLength": 120},
    "category": {"type": "string", "enum": ["fashion", "art", "lifestyle", "health", "gastronomy", "services", "retail", "technology", "other"]},
    "country": {"type": "string", "minLength": 2, "maxLength": 80},
    "city": {"type": "string", "minLength": 1, "maxLength": 100},
    "description": {"type": "string", "maxLength": 1000},
    "primary_product": {"type": "string", "minLength": 1, "maxLength": 240},
    "target_audience": {"type": "string", "minLength": 1, "maxLength": 500},
    "preferred_platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["instagram", "facebook", "tiktok", "whatsapp", "youtube", "x", "linkedin"]}
    },
    "primary_objective": {"type": "string", "enum": ["reach", "engagement", "sales", "store_visits", "launch", "brand_awareness", "community"]}
  }
}
