{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hitrendy.local/schemas/asset-analysis.schema.json",
  "title": "AssetAnalysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "strengths", "improvements", "revised_copy", "accessibility_notes"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 500},
    "strengths": {"type": "array", "minItems": 1, "maxItems": 6, "items": {"type": "string", "maxLength": 280}},
    "improvements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "area", "reason", "action"],
        "properties": {
          "priority": {"type": "string", "enum": ["high", "medium", "low"]},
          "area": {"type": "string", "enum": ["message", "hierarchy", "readability", "brand", "cta", "platform", "accessibility"]},
          "reason": {"type": "string", "maxLength": 300},
          "action": {"type": "string", "maxLength": 300}
        }
      }
    },
    "revised_copy": {"type": ["string", "null"], "maxLength": 1200},
    "accessibility_notes": {"type": "array", "maxItems": 6, "items": {"type": "string", "maxLength": 280}}
  }
}
