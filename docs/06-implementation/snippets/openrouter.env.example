# Copiar estas variables al .env del backend o a la configuración local.
# Nunca ponerlas en starter/web/.env.local con prefijo NEXT_PUBLIC_.

AI_PROVIDER=openai-compatible
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-reemplazar
AI_MODEL=openrouter/free
AI_TIMEOUT_SECONDS=45

# Mantener el análisis visual local mientras se valida el texto.
VISION_PROVIDER=demo
VISION_MODEL=demo-vision-v1
VISION_BASE_URL=
VISION_API_KEY=
