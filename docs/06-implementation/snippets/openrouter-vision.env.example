# Opcional: activar solo si el modelo elegido acepta imágenes y JSON.
# OpenRouter y el modelo deben soportar el formato OpenAI Chat Completions.

VISION_PROVIDER=openai-compatible
VISION_BASE_URL=https://openrouter.ai/api/v1
VISION_API_KEY=sk-or-v1-reemplazar
VISION_MODEL=modelo-multimodal-gratuito

# AI_* puede seguir apuntando al modelo de texto configurado por separado.
